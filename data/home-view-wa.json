        "title": "BHP committed to net zero by 2050. Leaked documents show it could be out of reach",
        "content": {
          "descriptor": {
            "type": "tagname",
            "key": "div",
            "props": {},
            "children": [
              {
                "type": "tagname",
                "key": "@@standfirst",
                "props": {},
                "children": [
                  {
                    "type": "text",
                    "content": "The mining giant's delay in the rollout of renewable energy and a fleet of electric trucks and trains in the Pilbara has raised doubts inside the company about it meeting its ambitious climate goal."
                  }
                ]
              }
            ]
          }
        },
        "dates": {
