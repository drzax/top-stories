        "label": null,
        "title": "Now James Valentine is gone, I'll let you in on the secret of his success ",
        "content": {
          "descriptor": {
            "type": "tagname",
            "key": "div",
            "props": {},
            "children": [
              {
                "type": "tagname",
                "key": "@@standfirst",
                "props": {},
                "children": [
                  {
                    "type": "text",
                    "content": "Children grew up with him, adults grew old with him, he kept us connected to our city, the world and each other. James helped us make sense of life and gave us permission to laugh at the absurdity of it all — and ourselves."
                  }
                ]
              }
            ]
          }
        },
        "dates": {
