            "children": [
              {
                "type": "tagname",
                "key": "@@standfirst",
                "props": {},
                "children": [
                  {
                    "type": "text",
                    "content": "An outbreak of measles in south-east Asia has fuelled a surge in NSW cases — but the state's biggest cause for concern is five infections believed to have been spread undetected in the community."
                  }
