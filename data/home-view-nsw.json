        "title": "PM pays tribute to 'personal friend' and former neighbour Richard Scolyer",
        "content": {
          "descriptor": {
            "type": "tagname",
            "key": "div",
            "props": {},
            "children": [
              {
                "type": "tagname",
                "key": "@@standfirst",
                "props": {},
                "children": [
                  {
                    "type": "text",
                    "content": "The family of former Australian of the Year Richard Scolyer have paid tribute to his legacy, saying he \"wanted cancer patients to know they weren't alone\"."
                  }
                ]
              }
            ]
          }
        },
        "dates": {
          "firstPublished": "2026-06-08T01:38:14+00:00",
          "lastUpdated": "2026-06-08T03:11:23+00:00"
        },
