            "children": [
              {
                "type": "tagname",
                "key": "@@standfirst",
                "props": {},
                "children": [
                  {
                    "type": "text",
                    "content": "The family of former Australian of the Year Richard Scolyer have paid tribute to his legacy, saying he \"wanted cancer patients to know they weren't alone\"."
